---
layout: page_base.njk
---

<div class="left">
    <!-- tags list -->
     <section class="green">
        <h3>Tagged with:</h3>
        <ul>
        {% for tag in journaltags %}
            <li>
                <a href="/journal/tagged/{{ tag | slugify }}">{{ tag }}</a>
            </li>
        {% endfor %}    
        </ul>
     </section>
</div>

<div class="right">
    <article class="blue">
        <h2>{{ title }}</h2>
        <small><em>posted on {{ postdate }}</em></small>
        {{ content | safe }}
    </article>
    <section class="yellow">
        <p>
            <a href="/journal"><- Return to journal index</a>
        </p>
    </section>
</div>